#!/usr/bin/env bash
# External sandbox for locking down the Pi coding agent (https://pi.dev)
# which only knows YOLO mode.
#
# Bars access to all directories except for the current working
# directory and needed system and configuration directories.
#
# NOTE: Networking is left intact.
#
# Troubleshoot with `strace --follow-forks -t -o strace.log pi-sandbox`
#
# Usage:
#
#   pi-sandbox PI_ARGS
#

WORK_DIR="$(pwd)"
readonly WORK_DIR

declare -a ARGS=()
ARGS+=(--new-session)
ARGS+=(--die-with-parent)
ARGS+=(--unshare-all)
ARGS+=(--share-net)
ARGS+=(--dev /dev)
ARGS+=(--proc /proc)
ARGS+=(--tmpfs /tmp)

# read-only: System programs and libraries
while read -r bind; do
    ARGS+=(--ro-bind-try "$bind" "$bind")
done <<EOF
/bin
/lib
/lib32
/lib64
/usr
EOF

# read-only: System configuration
ARGS+=(--dir /etc)
while read -r bind; do
    ARGS+=(--ro-bind-try "$bind" "$bind")
done <<EOF
/etc/alternatives
/etc/gai.conf
/etc/host.conf
/etc/hostname
/etc/hosts
/etc/hosts.allow
/etc/hosts.deny
/etc/ld.so.cache
/etc/ld.so.preload
/etc/localtime
/etc/nsswitch.conf
/etc/pki
/etc/resolv.conf
/etc/ssl
EOF


# Default empty /home
ARGS+=(--dir /home)

# read-only: Select paths under home directory
while read -r bind; do
    ARGS+=(--ro-bind-try "$bind" "$bind")
done <<EOF
$HOME/.local/bin
$HOME/.local/include
$HOME/.local/lib
$HOME/.local/lib64
$HOME/.local/share
EOF

# read/write: Pi agent configuration and current working directory
# Note: The `~/.pi` bind will expose any authentication tokens stored within to the agent itself.
while read -r bind; do
    ARGS+=(--bind "$bind" "$bind")
done <<EOF
$HOME/.pi
$WORK_DIR
EOF

# Bar write access to workspace critical directories to prevent agent tampering.
# Adjust if you want the agent to make code commit autonomously.
for d in .git .hg .pi; do
    ARGS+=(--ro-bind-try "$WORK_DIR/$d" "$WORK_DIR/$d")
done
readonly ARGS

exec bwrap --setenv PS1 "sandbox$ " "${ARGS[@]}" pi --offline "$@"
